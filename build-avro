# Configure CMake with static libraries

cmake ..   
-DCMAKE_BUILD_TYPE=Release   
-DCMAKE_INSTALL_PREFIX=”${INSTALL_PREFIX}”   
-DBOOST_ROOT=”${BOOST_DIR}”   
-DBoost_NO_SYSTEM_PATHS=ON   
-DBoost_NO_BOOST_CMAKE=ON   
-DBoost_USE_STATIC_LIBS=ON   
-DBoost_USE_STATIC_RUNTIME=OFF   
-DBOOST_INCLUDEDIR=”${BOOST_DIR}/include”   
-DBOOST_LIBRARYDIR=”${BOOST_LIB_DIR}”   
-DSnappy_INCLUDE_DIR=”${SNAPPY_INCLUDE_DIR}”   
-DSnappy_LIBRARY=”${SNAPPY_LIB_DIR}/libsnappy.a”   
-DCMAKE_CXX_STANDARD=11   
-DCMAKE_CXX_FLAGS=”${CXXFLAGS}”   
-DCMAKE_EXE_LINKER_FLAGS=”${LDFLAGS}”   
-DCMAKE_SHARED_LINKER_FLAGS=”${LDFLAGS}”   
-DBUILD_SHARED_LIBS=ON

echo “”
echo “Building Avro…”
make -j$(nproc)

echo “”
echo “Installing Avro…”

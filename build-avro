# Check if SNAPPY_DIR is a source directory
if [ -f "${SNAPPY_DIR}/CMakeLists.txt" ] || [ -f "${SNAPPY_DIR}/snappy.cc" ]; then
    echo "Building Snappy from source..."
    mkdir -p "${SNAPPY_DIR}/build-static"
    cd "${SNAPPY_DIR}/build-static"
    
    cmake .. \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX="${SNAPPY_INSTALL_DIR}" \
        -DBUILD_SHARED_LIBS=OFF \
        -DSNAPPY_BUILD_TESTS=OFF \
        -DSNAPPY_BUILD_BENCHMARKS=OFF \
        -DCMAKE_POSITION_INDEPENDENT_CODE=ON
    
    make -j$(nproc)
    make install
    
    SNAPPY_DIR="${SNAPPY_INSTALL_DIR}"
    echo "✓ Snappy built and installed to: ${SNAPPY_INSTALL_DIR}"
else
    echo "ERROR: SNAPPY_DIR does not appear to be a source directory: ${SNAPPY_DIR}"
    echo "Cannot build Snappy. Use --snappy-dir with path to Snappy source."
    exit 1
fi

echo “”
echo “=== Verifying static libraries ===”

REQUIRED_BOOST_LIBS=(
“libboost_program_options.a”
“libboost_iostreams.a”
“libboost_filesystem.a”
“libboost_system.a”
)

for lib in “${REQUIRED_BOOST_LIBS[@]}”; do
if [ ! -f “${BOOST_LIB_DIR}/${lib}” ]; then
echo “ERROR: Required Boost static library not found: ${BOOST_LIB_DIR}/${lib}”
echo “Try running with –build-boost flag”

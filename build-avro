#!/bin/bash
set -e

# Configuration - EDIT THESE PATHS

BOOST_VERSION=“1.74.0”
BOOST_UNDERSCORE_VERSION=“1_74_0”
SNAPPY_VERSION=“1.1.9”
AVRO_VERSION=“1.10.2”

# Default paths

BOOST_SOURCE_DIR=””
SNAPPY_DIR=””
AVRO_SOURCE_DIR=””
BUILD_DIR=”/tmp/avro-static-build”
INSTALL_PREFIX=”/opt/custom-libs/avro-${AVRO_VERSION}”
PACKAGE_OUTPUT_DIR=”/tmp/avro-packages”

# Flags

BUILD_BOOST=false
BUILD_SNAPPY=false
DOWNLOAD_SOURCES=false
SKIP_PACKAGE=false

# Parse command line arguments

while [[ $# -gt 0 ]]; do
case $1 in
–boost-source)
BOOST_SOURCE_DIR=”$2”
shift 2
;;
–snappy-dir)
SNAPPY_DIR=”$2”
shift 2
;;
–avro-source)
AVRO_SOURCE_DIR=”$2”
shift 2
;;
–build-dir)
BUILD_DIR=”$2”
shift 2
;;
–install-prefix)
INSTALL_PREFIX=”$2”
shift 2
;;
–output-dir)
PACKAGE_OUTPUT_DIR=”$2”
shift 2
;;
–build-boost)
BUILD_BOOST=true
shift
;;
–build-snappy)
BUILD_SNAPPY=true
shift
;;
–download)
DOWNLOAD_SOURCES=true
shift
;;
–skip-package)
SKIP_PACKAGE=true
shift
;;
–help)
cat << ‘HELP_EOF’
Usage: ./build-avro-static.sh [OPTIONS]

Build Avro C++ with statically linked Boost and Snappy dependencies.

Options:
–boost-source PATH       Path to Boost source directory (boost_1_74_0)
–snappy-dir PATH         Path to pre-built Snappy installation
–avro-source PATH        Path to Avro source directory
–build-dir PATH          Build directory (default: /tmp/avro-static-build)
–install-prefix PATH     Installation prefix (default: /opt/custom-libs/avro-1.10.2)
–output-dir PATH         Package output directory (default: /tmp/avro-packages)
–build-boost             Build Boost from source (requires –boost-source)
–build-snappy            Build Snappy from source (requires –snappy-dir to be source)
–download                Download all sources automatically
–skip-package            Skip packaging step, leave installed directory as-is
–help                    Show this help message

Examples:

# Build everything from downloaded sources

./build-avro-static.sh –download –build-boost –build-snappy

# Use existing Boost source, build Snappy and Avro

./build-avro-static.sh –boost-source ~/boost_1_74_0 –build-boost   
–snappy-dir ~/snappy –build-snappy   
–avro-source ~/avro-src-1.10.2

# Use pre-built Boost and Snappy

./build-avro-static.sh –boost-source /usr/local/boost-1.74.0   
–snappy-dir /usr/local/snappy   
–avro-source ~/avro-src-1.10.2
HELP_EOF
exit 0
;;
*)
echo “Unknown option: $1”
echo “Run with –help for usage information”
exit 1
;;
esac
done

# Create build directory

mkdir -p “${BUILD_DIR}”
mkdir -p “${PACKAGE_OUTPUT_DIR}”

# Download sources if requested

if [ “$DOWNLOAD_SOURCES” = true ]; then
echo “=== Downloading sources ===”
cd “${BUILD_DIR}”


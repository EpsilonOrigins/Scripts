PACKAGE_NAME=“avro-${AVRO_VERSION}-static-rhel9-x86_64.tar.gz”
cd “$(dirname ${INSTALL_PREFIX})”
tar czf “${PACKAGE_OUTPUT_DIR}/${PACKAGE_NAME}”   
–transform “s,^$(basename ${INSTALL_PREFIX}),avro-${AVRO_VERSION},”   
“$(basename ${INSTALL_PREFIX})”

# Generate checksum

cd “${PACKAGE_OUTPUT_DIR}”
sha256sum “${PACKAGE_NAME}” > “${PACKAGE_NAME}.sha256”

# Create deployment script

cat > “${PACKAGE_OUTPUT_DIR}/install-avro-static.sh” << ‘INSTALL_EOF’
#!/bin/bash
set -e

INSTALL_PREFIX=”/opt/custom-libs”
PACKAGE_NAME=“avro-1.10.2-static-rhel9-x86_64.tar.gz”

if [ “$1” != “” ]; then
INSTALL_PREFIX=”$1”
fi

echo “Installing Avro to: ${INSTALL_PREFIX}”
mkdir -p “${INSTALL_PREFIX}”
cd “${INSTALL_PREFIX}”

if [ -f “${PACKAGE_NAME}” ]; then
tar xzf “${PACKAGE_NAME}”
rm “${PACKAGE_NAME}”
echo “”
echo “Installation complete!”
echo “”
echo “To use Avro, add to your ~/.bashrc:”
echo “”
echo “export AVRO_HOME=${INSTALL_PREFIX}/avro-1.10.2”
echo “export PATH=${AVRO_HOME}/bin:${PATH}”
echo “export LD_LIBRARY_PATH=${AVRO_HOME}/lib:${LD_LIBRARY_PATH}”
echo “”
echo “Then verify: avrogencpp -h”
else
echo “ERROR: Package not found: ${PACKAGE_NAME}”
exit 1
fi
INSTALL_EOF

chmod +x “${PACKAGE_OUTPUT_DIR}/install-avro-static.sh”

# Summary

echo “”
echo “======================================”
echo “=== BUILD COMPLETE ===”
echo “======================================”
echo “”
echo “Package: ${PACKAGE_OUTPUT_DIR}/${PACKAGE_NAME}”
echo “Checksum: ${PACKAGE_OUTPUT_DIR}/${PACKAGE_NAME}.sha256”
echo “Installer: ${PACKAGE_OUTPUT_DIR}/install-avro-static.sh”
echo “”
ls -lh “${PACKAGE_OUTPUT_DIR}”
echo “”
echo “Installation verification:”
echo “  tar xzf ${PACKAGE_NAME}”
echo “  ldd avro-${AVRO_VERSION}/bin/avrogencpp”
echo “  (Should NOT show boost or snappy dependencies)”

# Determine library paths

BOOST_LIB_DIR=”${BOOST_DIR}/lib”
if [ -d “${BOOST_DIR}/stage/lib” ] && [ “$BUILD_BOOST” = false ]; then
BOOST_LIB_DIR=”${BOOST_DIR}/stage/lib”
